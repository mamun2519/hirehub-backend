datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  role      String   @default("candidate")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}
